# Copy this file to .env (not committed) and adjust as needed.

PORT=3001

# Used to sign JWTs. Anything random works for dev.
JWT_SECRET=dev-secret-please-change-me

# SQLite file. Created automatically.
DB_PATH=./server/data/dosewise.db

# Allowed origin for CORS (the Vite dev server).
CORS_ORIGIN=http://localhost:5173

# Optional. If set, AI companion uses Claude. Otherwise it falls back to keyword replies.
ANTHROPIC_API_KEY=
